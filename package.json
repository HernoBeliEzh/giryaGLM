{
  "name": "girya-glm",
  "version": "1.2.0",
  "description": "ГиряGLM — лёгкая программа для смены аккаунтов в ZCode desktop с показом лимитов GLM-5.2 / GLM-5-Turbo",
  "productName": "ГиряGLM",
  "main": "main.js",
  "author": "ГиряGLM",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.giryaglm.app",
    "productName": "ГиряGLM",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ГиряGLM"
    },
    "portable": {
      "artifactName": "ГиряGLM-Portable-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
